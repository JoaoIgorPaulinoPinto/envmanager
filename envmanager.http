# ==============================================================================
# GUIA RAPIDO
# ==============================================================================
# 1) Execute "Login" primeiro.
# 2) As variaveis accessToken e refreshToken sao preenchidas automaticamente.
# 3) Atualize lastUserId e lastProjectId conforme os dados do seu ambiente.
# ==============================================================================

### Configuracao de ambiente
@hostname = localhost
@port = 5115
@baseUrl = http://{{hostname}}:{{port}}
@contentType = application/json

# ==========================================
# 1. AUTENTICACAO E USUARIO
# ==========================================

### Variaveis de estado
@lastUserId = 6a57acf6607dc40d663efe10
@lastProjectId = 6a57b036607dc40d663efe16

### Tokens capturados da requisicao "Login"
@accessToken =eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjZhNTdhY2Y2NjA3ZGM0MGQ2NjNlZmUxMCIsImVtYWlsIjoiZGV2QGdtYWlsLmNvbSIsImp0aSI6IjFlYjI5YmExLTYxMjctNDEzOS1iZGFjLWQ4MTU3ODRkZGY4NiIsImV4cCI6MTc4NDEzNDkwOSwiaXNzIjoiZW52bWFuYWdlcl9hcGkiLCJhdWQiOiJlbnZtYW5hZ2VyX2FwaSJ9.WayDM2hlOKVj8M-wQvuf3dowCZUqYVXUwzftnwwjP2k
@refreshToken = DE7F5D123E3C909A7510226AE83A1538B806A284E64F133226F83E21D3EDEE8E
### 1.1 Cadastro de usuario
POST {{baseUrl}}/user
Content-Type: {{contentType}}

{
  "user_name": "Joao Igor",
  "email": "dev@gmail.com",
  "password": "1234"
}

### 1.2 Login
# @name login
POST {{baseUrl}}/auth
Content-Type: {{contentType}}

{
  "email": "dev@gmail.com",
  "password": "1234"
}

### 1.3 Refresh de sessao
POST {{baseUrl}}/auth/refresh
Content-Type: {{contentType}}

{
  "refreshToken": "E9E8DF4629A805E14A807DAC2A8D4FA8EAD5CE862EC65553B63765FFCFDBE8EB"
}

### 1.4 Logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "refreshToken": "{{refreshToken}}"
}

### 1.5 Listar todos os usuarios
GET {{baseUrl}}/user/all
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### 1.6 Usuario autenticado
GET {{baseUrl}}/user/me
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

# ==========================================
# 2. GESTAO DE PROJETOS
# ==========================================

### 2.1 Criar projeto
POST {{baseUrl}}/project
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "name": "Gitanalysos",
  "description": "Sistema de analises de repositorios de candidatos a vagas de tecnologia",
  "password": "123"
}

### 2.2 Listar projetos
GET {{baseUrl}}/project
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

### 2.3 Detalhes do projeto (sem senha)
POST {{baseUrl}}/project/{{lastProjectId}}/details
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{}

### 2.4 Detalhes do projeto (com senha)
POST {{baseUrl}}/project/{{lastProjectId}}/details
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "password": "123"
}

# ==========================================
# 3. CONFIGURACOES E MEMBROS
# ==========================================

### '3.1 Atualizar nome e descricao do projeto
PUT {{baseUrl}}/project/update 
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "project_id": "{{lastProjectId}}",
  "project_name": "Nome Modificado V2",
  "project_description": "Descricao atualizada via API"
}

### 3.2 Sincronizar variaveis (upsert)
PUT {{baseUrl}}/project/variables
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "project_id": "6a57b036607dc40d663efe16",
  "variables": [
    {
      "variable": "DEFAULT_API_KEY",
      "Value": "http://localhost:3000/"
    },
    {
      "variable": "DB_CONNECTION",
      "Value": ""
    }
  ]
}

### 3.3 Promover membro para administrador
PUT {{baseUrl}}/project/admin
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "user_id": "{{lastUserId}}",
  "project_id": "{{lastProjectId}}",
  "to_admin": true
}

### 3.4 Remover membro do projeto (kick member)
PUT {{baseUrl}}/project/kick
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "member_id": "{{lastUserId}}",
  "project_id": "{{lastProjectId}}"
}

### 3.5 Deletar projeto
DELETE {{baseUrl}}/project/delete
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

"{{lastProjectId}}"

### 3.6 Sair do projeto
DELETE {{baseUrl}}/project/exit?projectId={{lastProjectId}}
Authorization: Bearer {{accessToken}}
Accept: {{contentType}}

# ==========================================
# 4. CONVITES
# ==========================================

### 4.1 Enviar convite
POST {{baseUrl}}/invite 
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "invited_user_email": "pedroe@emaila.com",
  "project_id": "69aca1f3d66c153e0ccca8ef"
}

### 4.2 Responder convite (aceitar/recusar)
POST {{baseUrl}}/invite/answer
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "token": "COLE_O_TOKEN_DO_JWT_DO_CONVITE_AQUI",
  "accepted": true
}

